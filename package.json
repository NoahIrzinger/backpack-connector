{
  "name": "backpack-connector",
  "version": "0.1.11",
  "description": "Graph database projection connectors for Backpack learning graphs — unified MCP server, CLI, and adapter interface",
  "type": "module",
  "license": "Apache-2.0",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "backpack-connector": "dist/bin/cli.js",
    "backpack-connector-mcp": "dist/bin/mcp-server.js"
  },
  "scripts": {
    "build": "tsc && cp -r extensions dist/",
    "dev": "tsc --watch --preserveWatchOutput",
    "test": "vitest run tests/unit",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "npm test && npm run test:e2e",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "dependencies": {
    "backpack-ontology": "^0.8.3",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "puppeteer-core": "^24.42.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
